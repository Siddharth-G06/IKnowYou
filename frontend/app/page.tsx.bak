'use client';

import { Users, GitBranch, BookOpen, Plus, Search, ArrowRight, Clock } from 'lucide-react';
import PersonCard from '@/components/PersonCard';
import { Person } from '@/lib/types';
import Link from 'next/link';
import * as React from 'react';
import AddPersonModal from '@/components/AddPersonModal';
import AddRelationshipModal from '@/components/AddRelationshipModal';
import { useStats } from '@/hooks/useStats';
import { usePersons } from '@/hooks/usePersons';
import { mockPeople } from '@/lib/mockData';

export default function DashboardPage() {
  console.log('--- CANARY: DashboardPage is running from frontend/app/page.tsx ---');
  const [isAddPersonOpen, setIsAddPersonOpen] = React.useState(false);
  const [isAddRelOpen, setIsAddRelOpen] = React.useState(false);
  const [selectedPersonForRel, setSelectedPersonForRel] = React.useState<Person | null>(null);
  const { stats } = useStats();
  const { people, isLoading: isPeopleLoading } = usePersons();

  // Prefer real data, fallback to mock, and map to Person type
  const displayPeople = React.useMemo(() => {
    if (people && people.length > 0) {
      return (people as any[]).map(p => ({
        id: p.id,
        name: p.name,
        relation: p.relation || '',
        tags: (p.categories || []).map((cat: string) => ({ 
          label: cat, 
          category: (['family', 'friend', 'colleague', 'acquaintance', 'mentor', 'neighbor', 'other'].includes(cat.toLowerCase()) 
            ? cat.toLowerCase() 
            : 'other') 
        })),
        notes: p.notes || '',
        avatarColor: p.avatarColor || '#d48b3a'
      })) as Person[];
    }
    return mockPeople;
  }, [people]);

  const handleAddRelationship = (person: Person) => {
    setSelectedPersonForRel(person);
    setIsAddRelOpen(true);
  };

  return (
    <div
      style={{
        padding: '40px 36px',
        maxWidth: '960px',
        margin: '0 auto',
        fontFamily: 'var(--font-body)',
      }}
      className="dashboard-page fade-in"
    >
      {/* Header */}
      <header style={{ marginBottom: '40px' }}>
        <div
          style={{
            display: 'flex',
            alignItems: 'baseline',
            gap: '8px',
            marginBottom: '6px',
          }}
        >
          <h1
            style={{
              fontFamily: 'var(--font-heading)',
              fontSize: '32px',
              fontWeight: 700,
              color: 'var(--text-primary)',
              letterSpacing: '-0.02em',
              lineHeight: 1.2,
            }}
          >
            Hi Sid,
          </h1>
          <span
            style={{
              fontSize: '22px',
            }}
          >
            👋
          </span>
        </div>
        <p
          style={{
            fontSize: '16px',
            color: 'var(--text-secondary)',
            fontWeight: 400,
          }}
        >
          Who did you meet today?
        </p>
      </header>

      {/* Stats Row */}
      <section style={{ marginBottom: '36px' }}>
        <div
          style={{
            display: 'grid',
            gridTemplateColumns: 'repeat(3, 1fr)',
            gap: '16px',
          }}
          className="stats-grid"
        >
          {[
            {
              label: 'People in network',
              value: stats?.total_persons ?? 0,
              icon: Users,
              color: 'var(--amber)',
              bgColor: 'var(--amber-glow)',
            },
            {
              label: 'Relationships mapped',
              value: stats?.total_relationships ?? 0,
              icon: GitBranch,
              color: 'var(--indigo)',
              bgColor: 'var(--indigo-glow)',
            },
            {
              label: 'Memories logged',
              value: stats?.total_memories ?? 0,
              icon: BookOpen,
              color: 'var(--emerald)',
              bgColor: 'var(--emerald-glow)',
            },
          ].map(({ label, value, icon: Icon, color, bgColor }) => (
            <div
              key={label}
              style={{
                backgroundColor: 'var(--bg-elevated)',
                border: '1px solid var(--border)',
                borderRadius: '14px',
                padding: '24px 22px',
                position: 'relative',
                overflow: 'hidden',
                transition: 'border-color 0.2s ease, box-shadow 0.2s ease',
              }}
              onMouseEnter={(e) => {
                const el = e.currentTarget;
                el.style.borderColor = color;
                el.style.boxShadow = `0 0 0 1px ${color}44, 0 8px 24px rgba(0,0,0,0.3)`;
              }}
              onMouseLeave={(e) => {
                const el = e.currentTarget;
                el.style.borderColor = 'var(--border)';
                el.style.boxShadow = 'none';
              }}
            >
              {/* BG gradient top corner */}
              <div
                style={{
                  position: 'absolute',
                  top: '-20px',
                  right: '-20px',
                  width: '80px',
                  height: '80px',
                  borderRadius: '50%',
                  background: bgColor,
                  filter: 'blur(20px)',
                  pointerEvents: 'none',
                }}
              />
              <div
                style={{
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'space-between',
                  marginBottom: '16px',
                }}
              >
                <p
                  style={{
                    fontSize: '12px',
                    color: 'var(--text-muted)',
                    textTransform: 'uppercase',
                    letterSpacing: '0.07em',
                    fontWeight: 500,
                  }}
                >
                  {label}
                </p>
                <div
                  style={{
                    width: 32,
                    height: 32,
                    borderRadius: 8,
                    backgroundColor: bgColor,
                    display: 'flex',
                    alignItems: 'center',
                    justifyContent: 'center',
                  }}
                >
                  <Icon size={16} color={color} strokeWidth={1.75} />
                </div>
              </div>
              <p
                style={{
                  fontSize: '34px',
                  fontFamily: 'var(--font-heading)',
                  fontWeight: 700,
                  color: color,
                  lineHeight: 1,
                  letterSpacing: '-0.03em',
                }}
              >
                {value}
              </p>
            </div>
          ))}
        </div>
      </section>

      {/* Quick Actions */}
      <section style={{ marginBottom: '44px' }}>
        <h2
          style={{
            fontFamily: 'var(--font-heading)',
            fontSize: '11px',
            fontWeight: 500,
            color: 'var(--text-secondary)',
            marginBottom: '14px',
            letterSpacing: '0.07em',
            textTransform: 'uppercase',
          } as React.CSSProperties}
        >
          Quick Actions
        </h2>
        <div style={{ display: 'flex', gap: '12px', flexWrap: 'wrap' }}>
          {/* Add Person — filled amber */}
          <button
            onClick={() => setIsAddPersonOpen(true)}
            style={{
              display: 'inline-flex',
              alignItems: 'center',
              gap: '8px',
              padding: '11px 22px',
              borderRadius: '100px',
              border: 'none',
              backgroundColor: 'var(--amber)',
              color: '#0f0e0d',
              fontSize: '14px',
              fontWeight: 600,
              fontFamily: 'var(--font-body)',
              cursor: 'pointer',
              transition: 'all 0.2s ease',
              letterSpacing: '0.01em',
            }}
            onMouseEnter={(e) => {
              const el = e.currentTarget;
              el.style.backgroundColor = 'var(--amber-light)';
              el.style.transform = 'translateY(-1px)';
              el.style.boxShadow = '0 6px 20px rgba(212,139,58,0.35)';
            }}
            onMouseLeave={(e) => {
              const el = e.currentTarget;
              el.style.backgroundColor = 'var(--amber)';
              el.style.transform = 'translateY(0)';
              el.style.boxShadow = 'none';
            }}
          >
            <Plus size={16} strokeWidth={2.5} />
            Add Person
          </button>

          {/* Search — outlined */}
          <Link href="/search" style={{ textDecoration: 'none' }}>
            <button
              style={{
                display: 'inline-flex',
                alignItems: 'center',
                gap: '8px',
                padding: '11px 22px',
                borderRadius: '100px',
                border: '1px solid var(--border)',
                backgroundColor: 'transparent',
                color: 'var(--text-secondary)',
                fontSize: '14px',
                fontWeight: 500,
                fontFamily: 'var(--font-body)',
                cursor: 'pointer',
                transition: 'all 0.2s ease',
                letterSpacing: '0.01em',
              }}
              onMouseEnter={(e) => {
                const el = e.currentTarget;
                el.style.borderColor = 'var(--amber-dim)';
                el.style.backgroundColor = 'var(--amber-glow)';
                el.style.color = 'var(--amber)';
              }}
              onMouseLeave={(e) => {
                const el = e.currentTarget;
                el.style.borderColor = 'var(--border)';
                el.style.backgroundColor = 'transparent';
                el.style.color = 'var(--text-secondary)';
              }}
            >
              <Search size={15} strokeWidth={2} />
              Search
            </button>
          </Link>

          {/* View Graph — outlined */}
          <Link href="/graph" style={{ textDecoration: 'none' }}>
            <button
              style={{
                display: 'inline-flex',
                alignItems: 'center',
                gap: '8px',
                padding: '11px 22px',
                borderRadius: '100px',
                border: '1px solid var(--border)',
                backgroundColor: 'transparent',
                color: 'var(--text-secondary)',
                fontSize: '14px',
                fontWeight: 500,
                fontFamily: 'var(--font-body)',
                cursor: 'pointer',
                transition: 'all 0.2s ease',
              }}
              onMouseEnter={(e) => {
                const el = e.currentTarget;
                el.style.borderColor = 'var(--border)';
                el.style.backgroundColor = 'var(--bg-hover)';
                el.style.color = 'var(--text-primary)';
              }}
              onMouseLeave={(e) => {
                const el = e.currentTarget;
                el.style.backgroundColor = 'transparent';
                el.style.color = 'var(--text-secondary)';
              }}
            >
              <GitBranch size={15} strokeWidth={1.75} />
              View Tree
            </button>
          </Link>
        </div>
      </section>

      {/* Recent People */}
      <section>
        <div
          style={{
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'space-between',
            marginBottom: '18px',
          }}
        >
          <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
            <Clock size={14} color="var(--amber)" strokeWidth={2} />
            <h2
              style={{
                fontFamily: 'var(--font-heading)',
                fontSize: '11px',
                fontWeight: 500,
                color: 'var(--text-secondary)',
                textTransform: 'uppercase',
                letterSpacing: '0.07em',
              }}
            >
              Recent People
            </h2>
          </div>
          <Link
            href="/people"
            style={{
              display: 'flex',
              alignItems: 'center',
              gap: '4px',
              fontSize: '13px',
              color: 'var(--amber)',
              textDecoration: 'none',
              fontWeight: 500,
              transition: 'opacity 0.15s',
            }}
            onMouseEnter={(e) => { e.currentTarget.style.opacity = '0.75'; }}
            onMouseLeave={(e) => { e.currentTarget.style.opacity = '1'; }}
          >
            View All <ArrowRight size={13} />
          </Link>
        </div>

        <div
          className="people-grid"
          style={{
            display: 'grid',
            gridTemplateColumns: 'repeat(3, 1fr)',
            gap: '16px',
          }}
        >
          {displayPeople.map((person) => (
            <PersonCard 
              key={person.id} 
              person={person} 
              onAddRelationship={handleAddRelationship}
            />
          ))}
        </div>
      </section>

      {/* Modals */}
      <AddPersonModal
        isOpen={isAddPersonOpen}
        onClose={() => setIsAddPersonOpen(false)}
        onSuccess={() => {
          // Refresh list if needed (mocked for now)
          console.log('Person added, refreshing...');
        }}
      />

      {selectedPersonForRel && (
        <AddRelationshipModal
          isOpen={isAddRelOpen}
          onClose={() => setIsAddRelOpen(false)}
          toPerson={selectedPersonForRel}
          onSuccess={() => {
            console.log('Relationship added');
          }}
        />
      )}

      <style>{`
        @media (max-width: 900px) {
          .stats-grid { grid-template-columns: repeat(2, 1fr) !important; }
          .people-grid { grid-template-columns: repeat(2, 1fr) !important; }
          .dashboard-page { padding: 28px 20px !important; }
        }
        @media (max-width: 600px) {
          .stats-grid { grid-template-columns: 1fr !important; }
          .people-grid { grid-template-columns: 1fr !important; }
          .dashboard-page { padding: 20px 14px !important; }
        }
      `}</style>
    </div>
  );
}
